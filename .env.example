# Rezvo.app Backend Environment Variables
# Copy to backend/.env and fill in real values

MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=rezvo
JWT_SECRET=change-me-to-a-real-secret

# Stripe Connect
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Places API (for directory population)
GOOGLE_PLACES_API_KEY=...

# Uber Direct (delivery integration)
UBER_DIRECT_CLIENT_ID=...
UBER_DIRECT_CLIENT_SECRET=...

# CORS - allowed origins
CORS_ORIGINS=https://rezvo.app,https://rezvo.co.uk,http://localhost:5173
